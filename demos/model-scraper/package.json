{
	"name": "model-scraper",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "CLOUDFLARE_ENV=development vite",
		"start": "npm run dev",
		"build": "vite build",
		"preview": "npm run build && vite preview",
		"deploy": "npm run build && npm run deploy:production",
		"deploy:production": "wrangler deploy -e production",
		"deploy:staging": "wrangler deploy -e staging",
		"format": "oxfmt --write .",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"test:ci": "vitest --watch=false",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@ai-sdk/openai": "^3.0.48",
		"agents": "^0.8.6",
		"ai": "^6.0.138",
		"hono": "^4.12.9",
		"workers-ai-provider": "^3.1.8",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.30.1",
		"@cloudflare/vitest-pool-workers": "^0.13.4",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"typescript": "6.0.2",
		"vite": "^8.0.3",
		"vitest": "~4.1.1",
		"wrangler": "^4.77.0"
	}
}
